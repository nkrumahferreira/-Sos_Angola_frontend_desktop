# Base URL da API (opcional). Em browser, o app usa o host da página.
# Ex.: abrir http://192.168.0.126:8080 faz pedidos a http://192.168.0.126:8000
# (transmissão ao vivo na LAN). Só defina se o backend estiver noutra porta/host.
# VUE_APP_API_BASE_URL=http://localhost:8000

# TURN (opcional): para WebRTC quando P2P falha (NAT/firewall)
# VUE_APP_TURN_URIS=turn:seu-servidor:3478
# VUE_APP_TURN_USER=
# VUE_APP_TURN_CREDENTIAL=
